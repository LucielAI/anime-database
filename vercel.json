{
  "rewrites": [
    {
      "source": "/universe/:slug",
      "destination": "/api/index"
    },
    {
      "source": "/universe/:slug/",
      "destination": "/api/index"
    },
    {
      "source": "/((?!assets/|api/|src/data/|blog-index\\.json|blog/|search-index\\.json|manifest\\.json|sw\\.js|feed\\.xml|sitemap\\.xml|llms\\.txt|robots\\.txt|favicon\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}
