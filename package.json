{
  "name": "anime-archive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generateSitemap.js && node scripts/generateLlms.js && node scripts/generateSearchIndex.js && node scripts/generateBlogIndex.js && vite build",
    "generate:sitemap": "node scripts/generateSitemap.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "validate:payload": "node scripts/validatePayload.js",
    "add:universe": "node scripts/addUniverseWithSitemap.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:all": "node scripts/auditPayloads.js && node scripts/validateCatalogCoverage.js && node scripts/validateIndexing.js",
    "validate:indexing": "node scripts/validateIndexing.js",
    "validate:catalog": "node scripts/validateCatalogCoverage.js",
    "pipeline": "node scripts/runPipeline.js",
    "pipeline:check": "node scripts/runPipeline.js --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^1.3.1",
    "d3-force": "^3.0.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.1",
    "vitest": "^4.0.18"
  }
}