#!/bin/bash
# Pre-commit hook — runs enforce-universe-quality.sh before any commit
cd "$(git rev-parse --show-toplevel)"
bash scripts/enforce-universe-quality.sh > /tmp/enforce-output.txt 2>&1
exit_code=$?
if [ $exit_code -ne 0 ]; then
    echo "❌ ENFORCEMENT FAILED — fix errors before committing"
    cat /tmp/enforce-output.txt
    exit 1
fi
echo "✅ Enforcement passed"
exit 0
